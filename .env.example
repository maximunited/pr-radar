# GitHub token — primary token for GitHub API calls
# Falls back to the user's GitHub OAuth token via Clerk if not set
GITHUB_TOKEN=

# Clerk — injected automatically by Vercel Clerk integration
# For local dev: copy from clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Upstash Redis — injected automatically by Vercel Upstash integration
# For local dev: copy from upstash.com or Vercel integration page
KV_REST_API_URL=
KV_REST_API_TOKEN=
# UPSTASH_REDIS_REST_URL=   # alternative name (same value)
# UPSTASH_REDIS_REST_TOKEN=

# Cron endpoint protection (set in Vercel env vars)
CRON_SECRET=

# Cache TTL in seconds (default: 300 = 5 min)
CACHE_TTL=300
