# GitHub token (optional — falls back to `gh auth token`, then OAuth)
GITHUB_TOKEN=

# Upstash Redis — Vercel integration injects KV_* names automatically.
# For manual local setup, use the UPSTASH_* names instead.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# GitHub OAuth App (required for hosted multi-user)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Cache TTL in seconds (default: 300 = 5 min)
CACHE_TTL=300
